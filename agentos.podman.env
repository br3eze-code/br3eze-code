# AgentOS Podman environment
# Copy to agentos.podman.env.local and set AGENTOS_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   AGENTOS_PODMAN_ENV=/path/to/agentos.podman.env ./scripts/run-agentos-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-agentos-podman.sh which can generate it).
AGENTOS_GATEWAY_TOKEN=b3e35062507272831797730183561204

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
AGENTOS_PODMAN_GATEWAY_HOST_PORT=19876
AGENTOS_PODMAN_BRIDGE_HOST_PORT=19877

# Gateway bind (used by the launch script)
AGENTOS_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
