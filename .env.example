# ═══════════════════════════════════════════════════════════════════
# AgentOS — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── MikroTik Router ─────────────────────────────────────────────────
MIKROTIK_IP=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASS=

# ── Telegram Bot ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── AI Providers (set whichever you use) ────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Gateway ─────────────────────────────────────────────────────────
AGENTOS_GATEWAY_TOKEN=          # auto-generated if blank
AGENTOS_DASHBOARD_URL=http://localhost:3000

# ── Voucher / Billing ───────────────────────────────────────────────
# Prefix prepended to all generated voucher codes (e.g. VCH, NET, ISP)
VOUCHER_PREFIX=VCH
# Comma-separated plan names — must match MikroTik hotspot profile names
VOUCHER_PLANS=default,1day,7day,30day

# ── Brand / Operator Identity ───────────────────────────────────────
# Displayed in receipts, Mastercard A2A metadata, and the AI agent greeting
BRAND_SERVICE_NAME=AgentOS Hotspot
BRAND_RECIPIENT_NAME=AgentOS

# ── Mastercard A2A Commerce (optional) ─────────────────────────────
MASTERCARD_CONSUMER_KEY=
MASTERCARD_KEY_ALIAS=
MASTERCARD_KEY_PASSWORD=
MASTERCARD_P12_PATH=

# ── Firebase (optional — leave blank to use local SQLite) ───────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Profile ─────────────────────────────────────────────────────────
# 'default' uses ~/.agentos; any other value uses ~/.agentos-<profile>
AGENTOS_PROFILE=default
